# Django core
# Use lisa.settings.production on Vercel / any public host.
DJANGO_SETTINGS_MODULE=lisa.settings.production
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
# Optional: your custom domain, e.g. https://learn.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://learn.example.com

# Database
# Local default (no env needed): SQLite file db.sqlite3
# REQUIRED on Vercel — without Postgres, accounts vanish when /tmp SQLite resets:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# (Neon / Supabase / Vercel Postgres connection string works)

# Optional: Ollama for smarter speaking tutor replies (http://127.0.0.1:11434)
# OLLAMA_MODEL=llama3.2
